<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/gradient_background"
    >

    <com.google.android.material.textview.MaterialTextView
        android:id="@+id/titleText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="SLution"
        android:textSize="50sp"
        android:textStyle="bold"
        android:layout_centerHorizontal="true"
        android:fontFamily="@font/oleo_script_bold"
        android:layout_marginTop="50dp"
        android:textColor="#003092"/>

    <androidx.appcompat.widget.AppCompatImageView
        android:id="@+id/logoImage"
        android:layout_width="250dp"
        android:layout_height="250dp"
        android:src="@drawable/app_icon"
        android:layout_centerInParent="true"
        android:layout_below="@id/titleText"
        android:layout_marginTop="100dp" />

    <androidx.appcompat.widget.LinearLayoutCompat
        android:id="@+id/startActivityLinear"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:layout_marginHorizontal="40dp"
        android:layout_marginBottom="80dp">


        <com.google.android.material.button.MaterialButton
            android:id="@+id/new_account_button"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="New Account"
            android:textColor="@color/darkBlue"
            android:fontFamily="@font/charm_bold"
            android:textAllCaps="true"
            android:backgroundTint="#FFF2DB"
            android:textStyle="bold|italic" />

        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/login_button"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Login"
            android:textColor="@color/darkBlue"
            android:fontFamily="@font/charm_bold"
            android:textAllCaps="true"
            android:backgroundTint="#FFF2DB"
            android:textStyle="bold|italic" />


    </androidx.appcompat.widget.LinearLayoutCompat>


</RelativeLayout>
